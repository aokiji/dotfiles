#!/bin/bash

function _get_gitlab_mrs_list_by_scope_and_state() {
	SCOPE=$1
	STATE=$2

	CACHE_FILE="/tmp/cache_gitlab_mrs_${SCOPE}_${STATE}"
	CACHE_TTL_SECONDS=300

	if [ -f "$CACHE_FILE" ]; then
		LAST_MOD=$(stat -c %Y "$CACHE_FILE")
		NOW=$(date +%s)
		DIFF=$((NOW - LAST_MOD))

		if [ "$DIFF" -lt "$CACHE_TTL_SECONDS" ]; then
			exec cat "$CACHE_FILE"
		fi
	fi

	if [ -n "$STATE" ]; then
		EXTRA_ARGS="--state $STATE"
	fi

	gitlab -g nico -o json merge-request list --scope $SCOPE $EXTRA_ARGS |
		jq -r '.[] | [.state, .created_at, .updated_at, .author.name, .assignees[0].name, .title, .web_url, .references.full] | join("\t")' |
		tee "$CACHE_FILE"
}

export -f _get_gitlab_mrs_list_by_scope_and_state

DEFAULT_SCOPES=("all" "assigned_to_me" "created_by_me")
DEFAULT_STATES=("opened" "closed")

STATES=(${DEFAULT_STATES[@]})
SCOPES=(${DEFAULT_SCOPES[@]})

while [[ -n "$1" ]]; do
	case "$1" in
	-t|--scopes)
		shift
		scopes_str=$1
		shift
		IFS=',' read -r -a SCOPES <<< "$scopes_str"
		;;
	-s|--states)
		shift
		states_str=$1
		shift
		IFS=',' read -r -a STATES <<< "$states_str"
		;;
	-h|--help)

		echo -e "gitlab_mrs -h|--help -t|--scopes [SCOPES] -s|--states [STATES]\n\n" 1>&2
		echo "SCOPES: unidos por , dentro del conjunto: [${DEFAULT_SCOPES[@]}]" 1>&2
		echo "STATES: unidos por , dentro del conjunto: [${DEFAULT_STATES[@]}]" 1>&2
		exit 0
		;;
	*)
		echo "Opcion '$1' no reconocida" 1>&2
		exit 1
		;;
	esac
done

parallel --colsep ' ' \
	_get_gitlab_mrs_list_by_scope_and_state {1} {2} \
	::: "${SCOPES[@]}" \
	::: "${STATES[@]}" | sort -u -k 3 -r
