#!/bin/bash

REDMINE_BASE_URL=$(cat ~/.config/redmine/url)

CACHE_FILE="/tmp/cache_redmine_queries"
CACHE_TTL_SECONDS=3600

if [ -f "$CACHE_FILE" ]; then
    LAST_MOD=$(stat -c %Y "$CACHE_FILE")
    NOW=$(date +%s)
    DIFF=$((NOW - LAST_MOD))

    if [ "$DIFF" -lt "$CACHE_TTL_SECONDS" ]; then
        cat "$CACHE_FILE"
        exit 0
    fi
fi

curl -s -H "X-Redmine-API-Key: $(cat ~/.config/redmine/api_key)" "$REDMINE_BASE_URL/queries.json" |
	jq -r '.queries[] | [.id, .name] | join("\t")' | tee "$CACHE_FILE"
